# ===========================================
# Rectoverso OS - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control!

# ===========================================
# SUPABASE CONFIGURATION (Required)
# ===========================================

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (safe to expose to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (NEVER expose to client - server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct PostgreSQL connection string (for migrations/scripts)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# ===========================================
# CORS CONFIGURATION
# ===========================================

# Comma-separated list of allowed origins (no spaces)
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# AI INTEGRATION (Optional)
# ===========================================

# OpenAI API key for AI Assistant
OPENAI_API_KEY=sk-your-openai-api-key

# ===========================================
# EMAIL INTEGRATION - RESEND (Optional)
# ===========================================

# Resend API key for transactional emails
RESEND_API_KEY=re_your-resend-api-key

# Email domain verified in Resend
RESEND_EMAIL_DOMAIN=rectoverso.com

# Default sender email (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@rectoverso.com

# ===========================================
# WHATSAPP INTEGRATION (Optional)
# ===========================================

# Green-API WhatsApp Business credentials
WHATSAPP_ID_INSTANCE=your-instance-id
WHATSAPP_API_TOKEN=your-api-token

# ===========================================
# ANALYTICS - POSTHOG (Optional)
# ===========================================

# PostHog project API key (found in PostHog settings)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key

# PostHog host (usually https://app.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ===========================================
# ERROR TRACKING - SENTRY (Optional)
# ===========================================

# Sentry DSN for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Environment (development, staging, production)
NODE_ENV=development

# ===========================================
# REDIS CACHE (Optional - for production)
# ===========================================

REDIS_URL=redis://localhost:6379

# ===========================================
# APPLICATION SETTINGS
# ===========================================

# Application version (auto-set during build)
NEXT_PUBLIC_APP_VERSION=1.0.0

# API rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# DEVELOPMENT NOTES
# ===========================================
#
# 1. Get Supabase keys from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# 2. Get OpenAI key from: https://platform.openai.com/api-keys
# 3. Get Resend key from: https://resend.com/api-keys
# 4. Get PostHog key from: https://app.posthog.com/settings/project
# 5. Get Sentry DSN from: https://sentry.io/settings/YOUR_ORG/project
#
# IMPORTANT SECURITY NOTES:
# - NEVER commit .env.local or any file with real API keys
# - Use .gitignore to exclude .env* files
# - Rotate API keys immediately if they are compromised
# - The service role key has admin access - keep it secure!
