  "private": true,
  "description": "100% Production Ready Internal Operating System for Rectoverso Growth Technology",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "vitest --run --reporter=junit --outputFile=test-results/junit.xml",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:coverage": "vitest --run --coverage",
    "test:storybook": "test-storybook",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "format": "prettier --write \"src/**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,mdx}\" --cache",
    "prepare": "husky install",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
